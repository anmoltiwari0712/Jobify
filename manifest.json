{
  "manifest_version": 3,
  "name": "Jobify - Auto-Fill Job Applications",
  "version": "1.0.0",
  "description": "Fill job applications faster with a local-only profile stored in your browser.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "Jobify_Logo_Favicon_Pack/icon16.png",
      "48": "Jobify_Logo_Favicon_Pack/icon48.png",
      "128": "Jobify_Logo_Favicon_Pack/icon128.png"
    }
  },
  "icons": {
    "16": "Jobify_Logo_Favicon_Pack/icon16.png",
    "48": "Jobify_Logo_Favicon_Pack/icon48.png",
    "128": "Jobify_Logo_Favicon_Pack/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
